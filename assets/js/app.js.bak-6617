                          statusBadge(orderIsPaused(orderForStats||{})?'paused':((orderForStats&&orderForStats.status_slug)||'pending'), asArr(bs.statuses), lang),
                          currentStep && h(Badge,{label:(lang==='en'?'Current: ':'Ø§Ù„Ø­Ø§Ù„ÙŠØ©: ')+lnStep(currentStep,lang),color:'blue'}),
                          (orderForStats && (orderForStats.delivery_date || orderForStats.deadline)) && h(Badge,{label:(lang==='en'?'Delivery: ':'Ø§Ù„ØªØ³Ù„ÙŠÙ…: ')+fmtDate(orderForStats.delivery_date||orderForStats.deadline,lang),color:'gray'})
                        )
