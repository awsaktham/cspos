  return rem > 0 ? h+'h '+rem+'m' : h+'h';
}
function fmtDaysMin(m, lang) {
  m = Math.round(m || 0);
  if (m <= 0) return lang === 'en' ? '0 min' : '0 Ø¯';
  var days = Math.floor(m / 1440);
