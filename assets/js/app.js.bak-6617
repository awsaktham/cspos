        }),
        h(Btn, { variant:'primary', onClick:addOrUpdate, disabled:!/^\d{4}-\d{2}-\d{2}$/.test(draft||'') }, editIdx >= 0 ? (lang==='en'?'Update':'تحديث') : (lang==='en'?'Add':'إضافة')),
        editIdx >= 0 && h(Btn, { variant:'secondary', onClick:cancelEdit }, lang==='en'?'Cancel':'إلغاء')
      ),
