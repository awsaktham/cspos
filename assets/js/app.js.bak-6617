                placeholder: lang==='en' ? 'Type product number or name...' : 'Ø§ÙƒØªØ¨ Ø±Ù‚Ù… Ø§Ù„Ù…Ù†ØªØ¬ Ø£Ùˆ Ø§Ù„Ø§Ø³Ù…...',
