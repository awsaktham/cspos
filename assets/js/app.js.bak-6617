      h('div', { style:{ fontWeight:600, fontSize:13, marginBottom:8, color:T.text } },
        (lang==='en' ? 'WhatsApp Notify Number' : 'رقم واتساب للإشعارات')
      ),
      h('div', { style:{ display:'flex', alignItems:'center', gap:10, maxWidth:400, marginBottom:6 } },
        h('input', {
