        saved && h('span', { style:{ color:T.green, fontSize:13, fontWeight:600 } }, 'âœ… '+(lang==='en'?'Saved!':'ØªÙ… Ø§Ù„Ø­ÙØ¸!'))
      )
    ),

    /* â•â• Tab: Production Display â•â• */
    stab==='kds' && h(Card, { style:{ padding:'20px 24px', marginBottom:16 } },
