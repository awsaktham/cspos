                      h('div',null,
                        h('div',{style:{fontSize:28,fontWeight:900,color:T.text,fontFamily:'monospace'}},'#'+(orderForStats?orderForStats.order_number:'')),
                        h('div',{style:{fontSize:14,color:T.textMute,marginTop:8}},getCust(orderForStats||{},lang)),
