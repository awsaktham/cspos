    h('div', { style:{ border:'1px solid '+T.border, borderRadius:T.radius, padding:'8px 10px', background:T.bgSub, display:'grid', gridTemplateColumns:'repeat(auto-fill, minmax(140px, 1fr))', gap:'6px 12px' } },
      options.length === 0
