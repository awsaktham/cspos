                h('input', { value:r.step||'', onChange:function(e){ updateReason(r._id,'step',e.target.value); }, style:inSt, placeholder:lang==='en'?'e.g. Printing':'Ù…Ø«Ø§Ù„: Ø·Ø¨Ø§Ø¹Ø©' }),
                h('button', { onClick:function(){ removeReason(r._id); }, style:{ padding:'6px 11px', borderRadius:T.radius, border:'none', background:'#fee2e2', color:T.red, cursor:'pointer', fontWeight:700, fontSize:13 } }, 'X')
              );
