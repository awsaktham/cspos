          h('div',{style:{width:20,height:20,borderRadius:4,background:T.accent,display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}},
            h('span',{style:{color:'#fff',fontSize:12,fontWeight:700}},'âœ“')
          ),
          h('div',null,
